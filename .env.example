# Значения берутся в проекте Supabase на странице Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# DSN проекта в Sentry (Settings → Projects → <project> → Client Keys). Нужен
# и тут для локальной разработки, и как секрет репозитория VITE_SENTRY_DSN в
# GitHub Actions (см. .github/workflows/deploy-web.yml) — без него прод-сборка
# всё равно соберётся и будет работать как раньше, просто без отправки ошибок
VITE_SENTRY_DSN=

# Первая публичная версия остаётся бесплатной. Включать платежи можно только
# после подключения соответствующего провайдера для выбранного канала.
# web/direct: yookassa; google-play: Google Play Billing; rustore: RuStore Pay.
VITE_PAYMENTS_ENABLED=false
VITE_DISTRIBUTION_CHANNEL=web
