# Значения берутся в проекте Supabase на странице Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Канонический адрес веб-приложения для подтверждения OAuth и смены пароля.
# Этот адрес нужно также добавить в Supabase Auth → URL Configuration.
VITE_AUTH_REDIRECT_URL=https://app.myramusic.ru/

# Показываются только реально настроенные провайдеры Supabase. Для первого
# релиза рекомендуются Google и Discord. Пустое значение скрывает все кнопки.
VITE_OAUTH_PROVIDERS=

# Экспериментальные Supabase Passkeys. Включать только после настройки
# Authentication -> Passkeys и фиксации постоянного RP ID домена.
VITE_PASSKEYS_ENABLED=false

# DSN проекта в Sentry (Settings → Projects → <project> → Client Keys). Нужен
# и тут для локальной разработки, и как секрет репозитория VITE_SENTRY_DSN в
# GitHub Actions (см. .github/workflows/deploy-web.yml) — без него прод-сборка
# всё равно соберётся и будет работать как раньше, просто без отправки ошибок
VITE_SENTRY_DSN=

# Первая публичная версия остаётся бесплатной. Включать платежи можно только
# после подключения соответствующего провайдера для выбранного канала.
# web/direct: yookassa; google-play: Google Play Billing; rustore: RuStore Pay.
VITE_PAYMENTS_ENABLED=false
VITE_DISTRIBUTION_CHANNEL=web

# Никогда не включать в production. Разрешает локальную панель команды без
# серверной строки admins только в Vite DEV (`npm run dev`).
VITE_DEV_TOOLS=false
